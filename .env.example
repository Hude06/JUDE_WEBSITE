# App/runtime
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Admin CSRF allow-list override (optional):
# host:port value expected in Origin/Referer checks for mutating /api/admin/* calls.
# Example: admin.example.com
ADMIN_ALLOWED_HOST=

# Fleet stats endpoint protection (required if /api/fleet/stats is used)
FLEET_TOKEN=

# Build metadata for health/stats endpoints (optional but recommended)
BUILD_SHA=
BUILD_TIME=

# Optional analytics script injection
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SRC=

# Build-time flag used by this framework's Next.js config
# Leave empty in normal CI/local use.
SKIP_TYPE_CHECK=
